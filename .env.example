# ═══════════════════════════════════════════════════════════════════════════════
# POLYKALSH CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════
# POLYMARKET WALLET
# ═══════════════════════════════════════════
# Your Polymarket wallet private key (64 hex characters, with or without 0x prefix)
# Export from: Polymarket.com → Settings → Export Private Key
POLYMARKET_PRIVATE_KEY=

# Your funder/proxy address (the address shown in Polymarket UI)
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0 = EOA/MetaMask, 1 = Proxy/Email wallet (default: 1)
POLYMARKET_SIGNATURE_TYPE=1

# ═══════════════════════════════════════════
# KALSHI API (Read-only, for advisor)
# ═══════════════════════════════════════════
# Generate at: kalshi.com/account/settings/api-keys
KALSHI_API_KEY_ID=

# Path to your RSA private key PEM file
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Environment: prod or demo
KALSHI_ENV=prod

# ═══════════════════════════════════════════
# DISCORD NOTIFICATIONS
# ═══════════════════════════════════════════
# Main webhook for all notifications
DISCORD_WEBHOOK_URL=

# Optional: separate webhook for errors (leave empty to use main)
DISCORD_WEBHOOK_ERRORS=

# Your Discord user ID for @mentions on critical alerts
DISCORD_USER_ID=

# Mention you on critical alerts (true/false)
DISCORD_MENTION_ON_CRITICAL=true

# ═══════════════════════════════════════════
# DASHBOARD
# ═══════════════════════════════════════════
# Dashboard port (default: 8502)
DASHBOARD_PORT=8502

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=

# ═══════════════════════════════════════════
# COPY-TRADER SETTINGS
# ═══════════════════════════════════════════
# Master enable/disable for copy trading
COPY_ENABLED=true

# Paper trading mode (HIGHLY RECOMMENDED to start)
COPY_PAPER_MODE=true

# Paper trading starting balance (for simulation)
COPY_PAPER_STARTING_BALANCE=500.0

# Maximum USD per single trade
COPY_MAX_TRADE_USD=50.0

# Maximum total exposure across all positions
COPY_MAX_TOTAL_EXPOSURE_USD=500.0

# Maximum number of concurrent positions
COPY_MAX_POSITIONS=10

# Poll interval for checking leader activity (seconds)
COPY_POLL_INTERVAL_SEC=30

# ═══════════════════════════════════════════
# SAFETY GUARDS - ENTRY
# ═══════════════════════════════════════════
# Minimum orderbook liquidity (USD) to enter a trade
GUARD_MIN_LIQUIDITY_USD=1000.0

# Maximum bid-ask spread (percentage, 0.10 = 10%)
GUARD_MAX_SPREAD_PCT=0.10

# Minimum hours until market close to enter
GUARD_MIN_HOURS_TO_CLOSE=24.0

# Maximum price drift from leader's entry (percentage)
GUARD_MAX_PRICE_DRIFT_PCT=0.05

# ═══════════════════════════════════════════
# SAFETY GUARDS - EXIT
# ═══════════════════════════════════════════
# Stop loss percentage (0.25 = exit if down 25%)
GUARD_STOP_LOSS_PCT=0.25

# Take profit percentage (0.50 = exit if up 50%)
GUARD_TAKE_PROFIT_PCT=0.50

# Exit when leader exits (true/false)
GUARD_EXIT_ON_LEADER=true

# Auto-exit hours before market resolution
GUARD_EXIT_HOURS_BEFORE_CLOSE=2.0

# ═══════════════════════════════════════════
# SAFETY GUARDS - CIRCUIT BREAKERS
# ═══════════════════════════════════════════
# Daily loss limit in USD (pause trading if exceeded)
GUARD_DAILY_LOSS_LIMIT_USD=100.0

# Maximum consecutive losses before pause
GUARD_MAX_CONSECUTIVE_LOSSES=5

# Cooldown after loss (seconds)
GUARD_COOLDOWN_AFTER_LOSS_SEC=300

# ═══════════════════════════════════════════
# LEADER DISCOVERY
# ═══════════════════════════════════════════
# Auto-discover top wallets from leaderboard
LEADER_AUTO_DISCOVER=true

# Maximum leaders to track
LEADER_MAX_TRACKED=10

# Minimum PnL to consider a leader (USD)
LEADER_MIN_PNL_USD=1000.0

# Minimum volume to consider a leader (USD)
LEADER_MIN_VOLUME_USD=5000.0

# Time periods to scan: DAY, WEEK, MONTH, ALL (comma-separated)
LEADER_TIME_PERIODS=WEEK,MONTH

# ═══════════════════════════════════════════
# KALSHI ADVISOR
# ═══════════════════════════════════════════
# Enable Kalshi market scanning
ADVISOR_ENABLED=true

# Scan interval (minutes)
ADVISOR_SCAN_INTERVAL_MIN=30

# Minimum score to surface as recommendation (0-100)
ADVISOR_MIN_SCORE=70

# Minimum estimated edge to recommend
ADVISOR_MIN_EDGE_PCT=0.05

# Categories to scan (empty = all)
ADVISOR_CATEGORIES=

# ═══════════════════════════════════════════════════════════════════════════════
# KALSHI HYBRID TRADING BOT (AI-powered autonomous trading)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════
# Anthropic API key (for Lead Forecaster + Risk Manager agents)
AI_ANTHROPIC_API_KEY=

# Anthropic model (default: claude-sonnet-4-20250514)
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenRouter API key (for News Analyst + Bull/Bear Researchers)
AI_OPENROUTER_API_KEY=

# OpenRouter model (default: anthropic/claude-sonnet-4-20250514)
AI_OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# Perplexity API key (for deep research)
AI_PERPLEXITY_API_KEY=

# Perplexity model (default: llama-3.1-sonar-large-128k-online)
AI_PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online

# Max concurrent AI requests
AI_MAX_CONCURRENT_REQUESTS=5

# Request timeout (seconds)
AI_REQUEST_TIMEOUT_SEC=60

# ═══════════════════════════════════════════
# WEB SEARCH (Tavily)
# ═══════════════════════════════════════════
# Tavily API key for web search in chat advisor
# Get from: https://tavily.com
# Free tier: 1,000 searches/month
TAVILY_API_KEY=

# ═══════════════════════════════════════════
# HYBRID TRADING - MASTER CONTROLS
# ═══════════════════════════════════════════
# Enable/disable hybrid trading bot
HYBRID_ENABLED=true

# Paper trading mode (HIGHLY RECOMMENDED to start)
HYBRID_PAPER_MODE=true

# Paper trading starting balance
HYBRID_PAPER_STARTING_BALANCE=1000.0

# ═══════════════════════════════════════════
# HYBRID TRADING - DISCOVERY
# ═══════════════════════════════════════════
# Top N events by 24h volume to scan
HYBRID_TOP_EVENTS=50

# Top M markets per event
HYBRID_MARKETS_PER_EVENT=10

# Maximum days until expiry (skip longer-term)
HYBRID_MAX_EXPIRY_DAYS=30

# Minimum 24h volume to consider
HYBRID_MIN_VOLUME_24H=1000

# Skip markets where we have existing positions
HYBRID_SKIP_EXISTING_POSITIONS=true

# ═══════════════════════════════════════════
# HYBRID TRADING - POSITION LIMITS
# ═══════════════════════════════════════════
# Max % of portfolio per position (0.10 = 10%)
HYBRID_MAX_POSITION_PCT=0.10

# Max concurrent positions
HYBRID_MAX_CONCURRENT_POSITIONS=20

# Max USD per trade
HYBRID_MAX_BET_AMOUNT_USD=100.0

# ═══════════════════════════════════════════
# HYBRID TRADING - INTERVALS
# ═══════════════════════════════════════════
# Market scan interval (minutes)
HYBRID_SCAN_INTERVAL_MIN=15

# Exit check interval (minutes)
HYBRID_EXIT_CHECK_INTERVAL_MIN=5

# ═══════════════════════════════════════════
# AI ENSEMBLE - AGENT WEIGHTS
# ═══════════════════════════════════════════
# Weights must sum to 1.0
ENSEMBLE_LEAD_FORECASTER_WEIGHT=0.30
ENSEMBLE_NEWS_ANALYST_WEIGHT=0.20
ENSEMBLE_BULL_RESEARCHER_WEIGHT=0.20
ENSEMBLE_BEAR_RESEARCHER_WEIGHT=0.15
ENSEMBLE_RISK_MANAGER_WEIGHT=0.15

# ═══════════════════════════════════════════
# AI ENSEMBLE - THRESHOLDS
# ═══════════════════════════════════════════
# Minimum consensus confidence to trade (0.0-1.0)
ENSEMBLE_MIN_CONSENSUS_CONFIDENCE=0.60

# Max disagreement spread (std dev) - skip if agents disagree too much
ENSEMBLE_MAX_DISAGREEMENT_SPREAD=0.30

# Minimum edge to trade (0.05 = 5%)
ENSEMBLE_MIN_EDGE_TO_TRADE=0.05

# LLM temperature (0.0 = deterministic)
ENSEMBLE_TEMPERATURE=0.0

# Parallel batch size for AI calls
ENSEMBLE_PARALLEL_BATCH_SIZE=5

# ═══════════════════════════════════════════
# PORTFOLIO OPTIMIZATION
# ═══════════════════════════════════════════
# Kelly Criterion fraction (0.75 = 75% Kelly)
PORTFOLIO_KELLY_FRACTION=0.75

# Strategy allocation (must sum to 1.0)
PORTFOLIO_DIRECTIONAL_ALLOCATION=0.50
PORTFOLIO_MARKET_MAKING_ALLOCATION=0.40
PORTFOLIO_ARBITRAGE_ALLOCATION=0.10

# Hedging
PORTFOLIO_ENABLE_HEDGING=false
PORTFOLIO_HEDGE_RATIO=0.25
PORTFOLIO_MIN_CONFIDENCE_FOR_HEDGING=0.60
PORTFOLIO_MAX_HEDGE_AMOUNT_USD=50.0

# Risk limits
PORTFOLIO_MAX_DAILY_LOSS_PCT=0.15
PORTFOLIO_MAX_DRAWDOWN_PCT=0.50
PORTFOLIO_DAILY_AI_COST_LIMIT_USD=50.0

# ═══════════════════════════════════════════
# EXIT MANAGEMENT
# ═══════════════════════════════════════════
# Trailing take profit (0.20 = 20% profit)
EXIT_TRAILING_TAKE_PROFIT_PCT=0.20

# Trailing pullback (exit on 25% pullback from high)
EXIT_TRAILING_PULLBACK_PCT=0.25

# Stop loss (0.15 = 15% loss)
EXIT_STOP_LOSS_PCT=0.15

# Time limits
EXIT_MAX_HOLD_DAYS=10
EXIT_EXIT_HOURS_BEFORE_EXPIRY=4.0

# Confidence decay
EXIT_ENABLE_CONFIDENCE_DECAY=true
EXIT_CONFIDENCE_DECAY_THRESHOLD=0.50
EXIT_CONFIDENCE_RECHECK_HOURS=24

# Volatility adjustment
EXIT_VOLATILITY_STOP_MULTIPLIER=1.5

# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════
# SQLite database path (relative to project root)
DATABASE_PATH=./data/polykalsh.db

# ═══════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (leave empty for stdout only)
LOG_FILE_PATH=./data/polykalsh.log
